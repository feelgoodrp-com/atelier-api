# ============================================================
# atelier-api – Umgebungsvariablen
# Kopiere diese Datei nach .env.local und fülle die Werte aus.
# Bun lädt .env und .env.local automatisch (kein dotenv nötig).
# ============================================================

# HTTP-Port des Services
PORT=3095

# Optional: Bind-Adresse (Standard 127.0.0.1; für Deployment 0.0.0.0 setzen)
# HOST=127.0.0.1

# MongoDB-Verbindung (Atlas oder lokal) – PFLICHT
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/?retryWrites=true&w=majority

# Name der Datenbank (Standard: feelgoodrp)
MONGODB_DB_NAME=feelgoodrp

# Optional: DNS-Server für SRV-Lookups erzwingen (kommasepariert).
# Workaround für Bun unter Windows, wenn mongodb+srv:// mit
# "querySrv ECONNREFUSED" fehlschlägt.
# MONGODB_DNS_SERVERS=8.8.8.8

# Öffentliche Basis-URL dieses Services (wird als Discord-OAuth-Redirect verwendet:
# {ATELIER_PUBLIC_ORIGIN}/api/v1/auth/discord/callback)
ATELIER_PUBLIC_ORIGIN=http://127.0.0.1:3095

# Discord-Application (https://discord.com/developers/applications)
# Solange beide auf CHANGEME stehen UND ATELIER_DEV_FAKE_AUTH=1 ist,
# läuft der Fake-Login ohne echte Discord-App.
ATELIER_DISCORD_CLIENT_ID=CHANGEME
ATELIER_DISCORD_CLIENT_SECRET=CHANGEME

# Kommaseparierte Discord-IDs, die IMMER approved + admin sind
# (wird bei jedem Login/Refresh erzwungen)
ATELIER_ADMIN_DISCORD_IDS=

# Secret für Access-Token-JWTs (HS256) – PFLICHT, min. 32 Zeichen, zufällig generieren:
#   bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ATELIER_JWT_SECRET=

# Service-zu-Service-Token (Header x-fg-service-token) – PFLICHT, min. 16 Zeichen
# Wird später vom Registry-/Build-Service genutzt.
ATELIER_SERVICE_TOKEN=

# Wurzelverzeichnis für Datei-Storage (Uploads, Builds) – wird beim Start angelegt
ATELIER_STORAGE_ROOT=./data

# Upload-Chunkgröße in Bytes (Standard 8 MiB). Der Server gibt den Wert beim
# Upload-Init vor – Clients müssen ihn aus der Antwort übernehmen.
ATELIER_MAX_CHUNK_BYTES=8388608

# Maximale Größe einer einzelnen Asset-Datei in Bytes (Standard 256 MiB)
ATELIER_MAX_ASSET_BYTES=268435456

# Wie viele Server-Builds gleichzeitig laufen dürfen (Standard 2)
ATELIER_BUILD_CONCURRENCY=2

# Wurzel der creative-Cloth-Uploads (CLOTH_UPLOAD_ROOT von creative) für den
# einmaligen Import bestehender Packs. Leer = Import-Endpoint deaktiviert.
# Beispiel: C:\pfad\zu\creative\data\cloth-uploads
ATELIER_CREATIVE_CLOTH_ROOT=

# Dev-Fake-Auth: 1 = Login ohne Discord (nur wenn Discord-Creds CHANGEME/leer sind
# und NODE_ENV != production). Niemals in Production aktivieren!
ATELIER_DEV_FAKE_AUTH=0

# Discord-ID des Fake-Dev-Users (nur relevant bei ATELIER_DEV_FAKE_AUTH=1)
ATELIER_DEV_FAKE_DISCORD_ID=

# Nur hinter einem Reverse-Proxy auf 1 setzen: dann zaehlt der rechteste
# X-Forwarded-For-Eintrag (vom eigenen Proxy angehaengt) als Client-IP.
# Bei Direktverbindungen wird der Header ignoriert (Spoofing-Schutz).
ATELIER_TRUST_PROXY=0
